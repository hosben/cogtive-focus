import { serve } from "https://deno.land/std@0.168.0/http/server.ts"
import { createClient } from "https://esm.sh/@supabase/supabase-js@2"

const corsHeaders = {
  "Access-Control-Allow-Origin": "*",
  "Access-Control-Allow-Headers": "authorization, x-client-info, apikey, content-type",
  "Access-Control-Allow-Methods": "POST, OPTIONS",
}

const SCORING_PROMPT = `You are a priority scoring engine for a B2B SaaS startup in industrial manufacturing.

Given a list of signals (tasks, events, messages), select and rank the TOP 3 priorities for the user's workday.

For each priority output:
- rank (1, 2, or 3)
- title (concise action title, max 60 chars, in the user's language)
- reason (one sentence explaining WHY this is a priority today, in the user's language)
- score (0-100 composite score)
- badge (one of: "urgência alta", "impacto direto", "dependência de time", "fricção acumulada", "prazo hoje")
- source_signal_ids (array of signal IDs that justify this priority)

Scoring criteria:
- Urgency (40%): deadline proximity, dependencies blocking others
- Impact (35%): alignment with business outcomes, customer-facing risk
- Friction (25%): time stalled without update, risk of becoming technical debt

Respond ONLY with a valid JSON array of 3 objects. No preamble, no markdown, no explanation.
Language: detect from signal titles and respond in the same language (pt-BR expected).`

serve(async (req) => {
  if (req.method === "OPTIONS") {
    return new Response("ok", { status: 200, headers: corsHeaders })
  }

  try {
    const authHeader = req.headers.get("Authorization")
    if (!authHeader) {
      return new Response(JSON.stringify({ error: "Unauthorized" }), {
        status: 401,
        headers: { ...corsHeaders, "Content-Type": "application/json" }
      })
    }

    const supabase = createClient(
      Deno.env.get("SUPABASE_URL")!,
      Deno.env.get("SUPABASE_ANON_KEY")!,
      { global: { headers: { Authorization: authHeader } } }
    )

    const { data: { user }, error: authError } = await supabase.auth.getUser()
    if (authError || !user) {
      return new Response(JSON.stringify({ error: "Unauthorized" }), {
        status: 401,
        headers: { ...corsHeaders, "Content-Type": "application/json" }
      })
    }

    const { signals, date } = await req.json()

    if (!signals || signals.length === 0) {
      return new Response(JSON.stringify({ error: "No signals provided" }), {
        status: 400,
        headers: { ...corsHeaders, "Content-Type": "application/json" }
      })
    }

    const { data: overrideHistory } = await supabase
      .from("overrides")
      .select("override_title, replaced_priority_rank, created_at")
      .eq("user_id", user.id)
      .order("created_at", { ascending: false })
      .limit(20)

    const overrideContext = overrideHistory?.length
      ? `\n\nUser override history (learn from this to personalize): ${JSON.stringify(overrideHistory)}`
      : ""

    const anthropicRes = await fetch("https://api.anthropic.com/v1/messages", {
      method: "POST",
      headers: {
        "Content-Type": "application/json",
        "x-api-key": Deno.env.get("ANTHROPIC_API_KEY")!,
        "anthropic-version": "2023-06-01",
      },
      body: JSON.stringify({
        model: "claude-sonnet-4-20250514",
        max_tokens: 1000,
        system: SCORING_PROMPT + overrideContext,
        messages: [{
          role: "user",
          content: `Today's signals:\n${JSON.stringify(signals, null, 2)}`
        }]
      })
    })

    const anthropicData = await anthropicRes.json()
    const rawText = anthropicData.content?.[0]?.text

    let priorities
    try {
      priorities = JSON.parse(rawText)
    } catch {
      throw new Error("LLM returned invalid JSON: " + rawText)
    }

    const { data: session, error: sessionError } = await supabase
      .from("priority_sessions")
      .upsert({
        user_id: user.id,
        date: date || new Date().toISOString().split("T")[0],
        priorities,
      }, { onConflict: "user_id,date" })
      .select()
      .single()

    if (sessionError) throw sessionError

    return new Response(JSON.stringify({ priorities, session_id: session.id }), {
      headers: { ...corsHeaders, "Content-Type": "application/json" }
    })

  } catch (err) {
    console.error(err)
    return new Response(JSON.stringify({ error: err.message }), {
      status: 500,
      headers: { ...corsHeaders, "Content-Type": "application/json" }
    })
  }
})
